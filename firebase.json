{
  "hosting": {
    "target": "kyronis",
    "public": ".",
    "ignore": [
      "firebase.json",
      ".firebaserc",
      "package.json",
      "package-lock.json",
      "node_modules/**",
      ".firebase/**",
      "firebase-debug.log",
      "**/.*"
    ],
    "cleanUrls": true,
    "headers": [
      {
        "source": "index.html",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache"
          }
        ]
      },
      {
        "source": "**/*.@(css|js)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public,max-age=31536000,immutable"
          }
        ]
      }
    ]
  }
}
